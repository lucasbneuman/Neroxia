# ============================================================================
# WhatsApp Sales Bot - canonical environment template
# ============================================================================
# This is the only env example maintained by the repo.
# Copy it to .env and replace every placeholder before running the app.

# ============================================================================
# Supabase
# ============================================================================
# Supabase is the canonical database and auth provider for this project.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:6543/postgres

# Frontend public Supabase values. They must match the same Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ============================================================================
# Backend and frontend URLs
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# OpenAI
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================================================
# Twilio WhatsApp
# ============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ============================================================================
# HubSpot CRM (optional)
# ============================================================================
HUBSPOT_ACCESS_TOKEN=pat-na1-your-private-app-token

# ============================================================================
# Meta: Facebook, Instagram and Messenger (optional)
# ============================================================================
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_VERIFY_TOKEN=your-random-webhook-verify-token
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:8000/integrations/facebook/callback

# ============================================================================
# Runtime
# ============================================================================
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=7860
